
import requests
from bs4 import BeautifulSoup
import tldextract
from urllib.parse import urljoin , urlparse , urlunparse


def crawl(seed_url,max_crawl_depth,max_links):
    discovered_urls = []
    discovered_urls.append(seed_url) 
    urls_to_crawl = [(seed_url , 0)] #start with seed URL and depth zero
    main_domain = get_main_domain(seed_url) #get main domain 
    while urls_to_crawl:
        flag = False
        current_url , current_depth = urls_to_crawl.pop(0)
        #print(current_url)
        if max_crawl_depth is not None and current_depth >= max_crawl_depth:
            continue
        #print(current_url , current_depth)
        response = requests.get(current_url)
        if response.status_code == 200:
            soup = BeautifulSoup(response.text , "html.parser")
            for anchor_tag in soup.find_all("a"):
                href_value = anchor_tag.get("href")
                if href_value:
                    absolute_url = urljoin(seed_url,href_value)
                    if absolute_url not in discovered_urls and main_domain in absolute_url:
                        discovered_urls.append(absolute_url)
                        print(absolute_url)
                        urls_to_crawl.append((absolute_url,current_depth+1))
                        if max_links is not None and len(discovered_urls) >= max_links:
                            flag = True
                            break
                            
        if flag:
            break

    return discovered_urls
        
def get_main_domain(url):
    extracted = tldextract.extract(url)
    return f"{extracted.domain}.{extracted.suffix}" 

def main():
    results = [] #to save discovered urls 
    max_crawl_depth = None #a number to set the maximum crawl depth. Use None to crawl the entire website.
    max_links = None #a number to set the maximum number of links to discover. Use None to find all links.
    seed_url = "http://testphp.vulnweb.com" #a starting point
    results = crawl(seed_url, max_crawl_depth, max_links)
    
    """
    for url in results:
        print(url) """

if __name__ == "__main__":
    main()